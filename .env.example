# ─── S4Carlisle CMS — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in real values before running docker compose.
# NEVER commit .env to git. This .env.example file IS committed as documentation.
#
# Generate a strong SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# or:
#   openssl rand -hex 32

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=cms_user
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=cms_db

# ─── Application ─────────────────────────────────────────────────────────────
# Must match POSTGRES_* values above. In Docker, host is "db" (service name).
DATABASE_URL=postgresql://cms_user:change_me_strong_password_here@db:5432/cms_db

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# ─── Redis ───────────────────────────────────────────────────────────────────
# In Docker, host is "redis" (service name).
REDIS_URL=redis://redis:6379/0

# ─── Server ──────────────────────────────────────────────────────────────────
# The public-facing hostname or IP of this server, as reachable from browsers.
# Example: 192.168.1.100 or cms.mycompany.com
HOST_DOMAIN=10.1.1.18

# The external HTTP port nginx listens on (maps to container port 80).
HOST_PORT=8080

# ─── OnlyOffice ──────────────────────────────────────────────────────────────
# Public URL reachable by the BROWSER. This must point at the OnlyOffice
# Document Server itself — by default its container is published on host
# port 8083 (see docker-compose.yml `onlyoffice` -> "8083:80"), NOT the CMS
# nginx port (HOST_PORT). Use http://<HOST_DOMAIN>:8083 unless you proxy the
# OnlyOffice paths (/web-apps/, /cache/, /coauthoring/, ...) through Nginx.
ONLYOFFICE_PUBLIC_URL=http://10.1.1.18:8083
# Internal URL of the OnlyOffice container (reachable from the backend container).
ONLYOFFICE_INTERNAL_URL=http://onlyoffice:80
# JWT Secret for signing config payloads and verifying callback requests.
# Generate with: openssl rand -hex 32
ONLYOFFICE_JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
# Enable/disable JWT verification
ONLYOFFICE_JWT_ENABLED=true

# ─── Collabora ───────────────────────────────────────────────────────────────
# Internal URL of the Collabora container (reachable from backend container).
COLLABORA_URL=http://collabora:9980
# Public URL reachable by the browser (routed via Nginx).
# Use your server's actual IP or domain — NOT localhost (localhost resolves on
# the client browser machine, not the server).
COLLABORA_PUBLIC_URL=http://10.1.1.18:8080
# WOPI base URL used by the Collabora container to call back to the backend.
# Keep this as the Docker service name — the backend container is not published
# to the host network (only "expose"d), so host.docker.internal will not work.
WOPI_BASE_URL=http://backend:8000


# ─── AI Structuring Service (optional) ──────────────────────────────────────
# Leave AI_STRUCTURING_BASE_URL empty to disable the external AI service.
# When set, the CMS offloads structuring jobs to this container.
AI_STRUCTURING_BASE_URL=http://ai_structuring:5000
AI_STRUCTURING_API_KEY=

# Advanced AI structuring settings (defaults are usually fine)
AI_STRUCTURING_DOCUMENT_TYPE=Academic Document
AI_STRUCTURING_USE_MARKERS=false
AI_STRUCTURING_POLL_INTERVAL_SECONDS=2
AI_STRUCTURING_MAX_WAIT_SECONDS=900
AI_STRUCTURING_REQUEST_TIMEOUT_SECONDS=30

# ─── External PPH Server Processing (optional) ──────────────────────────────
# When enabled, the CMS offloads processing jobs to the external PPH server.
PPH_ENABLED=false
PPH_BASE_URL=http://10.1.1.69:8081
PPH_USERNAME=admin
PPH_PASSWORD=admin123
PPH_MAX_WAIT_SECONDS=1800

# ─── PPH Reference Conversion Settings (for reference_structuring) ────────────
# Source citation style: Auto, AMA, APA, CGRN
REF_SOURCE_STYLE=Auto

# Target citation style: AMA, APA, CGRN
REF_TARGET_STYLE=APA

