# ─── S4Carlisle CMS — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in real values before running docker compose.
# NEVER commit .env to git. This .env.example file IS committed as documentation.
#
# Generate a strong SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# or:
#   openssl rand -hex 32

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=cms_user
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=cms_db

# ─── Application ─────────────────────────────────────────────────────────────
# Must match POSTGRES_* values above. In Docker, host is "db" (service name).
DATABASE_URL=postgresql://cms_user:change_me_strong_password_here@db:5432/cms_db

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# ─── Redis ───────────────────────────────────────────────────────────────────
# In Docker, host is "redis" (service name).
REDIS_URL=redis://redis:6379/0

# ─── Server / Collabora ──────────────────────────────────────────────────────
# The public-facing hostname or IP of this server, as reachable from browsers.
# This is embedded in the Collabora WOPI editor URL so browsers can connect.
# Example: 192.168.1.100 or cms.mycompany.com
HOST_DOMAIN=10.1.1.18

# The external HTTP port nginx listens on (maps to container port 80).
HOST_PORT=8080

# ─── AI Structuring Service (optional) ──────────────────────────────────────
# Leave AI_STRUCTURING_BASE_URL empty to disable the external AI service.
# When set, the CMS offloads structuring jobs to this container.
AI_STRUCTURING_BASE_URL=http://ai_structuring:5000
AI_STRUCTURING_API_KEY=

# Advanced AI structuring settings (defaults are usually fine)
AI_STRUCTURING_DOCUMENT_TYPE=Academic Document
AI_STRUCTURING_USE_MARKERS=false
AI_STRUCTURING_POLL_INTERVAL_SECONDS=2
AI_STRUCTURING_MAX_WAIT_SECONDS=900
AI_STRUCTURING_REQUEST_TIMEOUT_SECONDS=30
