# ─── Frontend (Vite) — Environment Variables ─────────────────────────────────
# Copy this file to frontend/.env for local development overrides.
# In production Docker builds, these are not needed — the app uses
# same-origin relative API calls routed through nginx.
#
# VITE_ prefix is required for Vite to expose variables to browser code.

# ─── Dev server proxy ────────────────────────────────────────────────────────
# Where the Vite dev server should proxy /api/* requests during development.
# Must match the port your local FastAPI backend is running on.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# ─── SSR origin override (optional) ─────────────────────────────────────────
# Only needed if the SSR (legacy) pages are served from a different origin.
# Leave blank in production — the app automatically uses window.location.origin.
# VITE_API_BASE_URL=http://127.0.0.1:8000
