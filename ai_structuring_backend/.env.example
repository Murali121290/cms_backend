# ─── AI Structuring Backend — Environment Variables ──────────────────────────
# Copy this file to ai_structuring_backend/.env and fill in real values.
# NEVER commit .env to git.

# ─── Flask / Application ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

FLASK_ENV=production
FLASK_DEBUG=0

# ─── Database ─────────────────────────────────────────────────────────────────
# Same PostgreSQL instance as the main CMS (service name "db" in Docker network)
DATABASE_URL=postgresql://cms_user:change_me_strong_password_here@db:5432/cms_db

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── AI / LLM API Keys (set whichever provider is in use) ────────────────────
# Google Gemini
GEMINI_API_KEY=

# OpenAI (if used)
OPENAI_API_KEY=

# Anthropic Claude (if used)
ANTHROPIC_API_KEY=

# ─── Service settings ─────────────────────────────────────────────────────────
# Maximum file size for uploads (bytes)
MAX_CONTENT_LENGTH=104857600
