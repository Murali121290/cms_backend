{
  "rules": [
    {
      "id": "URL001",
      "name": "Validate Internal XHTML Links",
      "function": "validate_internal_xhtml_links",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": ["*_chapter*.xhtml", "*_ch*.xhtml"]
    },
    {
      "id": "URL002",
      "name": "Validate External URLs",
      "function": "validate_external_urls",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": ["*_chapter*.xhtml", "*_ch*.xhtml"]
    },
    {
      "id": "URL003",
      "name": "Validate URL Text Match",
      "function": "validate_url_text_match",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": ["*_chapter*.xhtml", "*_ch*.xhtml"]
    },
    {
      "id": "NAV001",
      "name": "Validate NAV TOC Headings",
      "function": "validate_nav_headings",
      "target_path": "",
      "enabled": true,
      "file_name_pattern": "nav.xhtml"
    },
    {
      "id": "NAV002",
      "name": "Validate TOC NCX Headings",
      "function": "validate_ncx_headings",
      "target_path": "",
      "enabled": true,
      "file_name_pattern": "toc.ncx"
    },
    {
      "id": "CSS001",
      "name": "Validate CSS Files via W3C Validator",
      "function": "validate_css_w3c",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": "*.xhtml"
    },
    {
      "id": "CSS002",
      "name": "Validate CSS Files Directly via W3C Validator",
      "function": "validate_css_w3c",
      "target_path": "OEBPS/css",
      "enabled": true,
      "file_name_pattern": "*.css"
    },
    {
      "id": "URL004",
      "name": "PDF-EPUB Link Checker (broken anchors + missing links)",
      "function": "validate_pdf_link_checker",
      "scope": "book",
      "enabled": true
    },
    {
      "id": "NAV003",
      "name": "PDF-EPUB Nav Validator (heading coverage + hierarchy + EISBN)",
      "function": "validate_nav_full",
      "scope": "book",
      "enabled": true
    },
    {
      "id": "PDF001",
      "name": "PDF-EPUB Style Parity (italic, alignment, indent, images, colour, page count)",
      "function": "validate_pdf_style_parity",
      "scope": "book",
      "enabled": true
    },
    {
      "id": "PAGE001",
      "name": "Validate Pagebreak Position",
      "function": "validate_pagebreak_positions",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": "*.xhtml"
    }
  ]
}
